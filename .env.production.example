# Copy to .env.production (gitignored) and set strong values before prod compose.
# Usage: docker compose -f infra/docker-compose.prod.yml --env-file .env.production up -d --build

POSTGRES_DB=nakama
POSTGRES_PASSWORD=change-me-long-random

# Client socket auth (must match frontend VITE_NAKAMA_SERVER_KEY when you deploy FE).
NAKAMA_SERVER_KEY=change-me-long-random

# HTTP RPC key (curl / tools use ?http_key=...). Change from defaulthttpkey for any public host.
NAKAMA_HTTP_KEY=defaulthttpkey

NAKAMA_LOG_LEVEL=WARN
SESSION_TOKEN_EXPIRY_SEC=3600
